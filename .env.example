# 通用配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_API_KEY=

# 兼容旧配置，OpenAI 默认仍会读取这个变量
OPENAI_API_KEY=

# 千问 / DashScope 示例
# LLM_PROVIDER=dashscope
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=your_dashscope_api_key

# 豆包 / 火山方舟示例
# LLM_PROVIDER=doubao
# LLM_MODEL=your_doubao_endpoint_id
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_API_KEY=your_ark_api_key

# 自定义兼容 OpenAI 协议的模型服务
# LLM_PROVIDER=custom
# LLM_MODEL=your_model_name
# LLM_BASE_URL=https://your-compatible-endpoint/v1
# LLM_API_KEY=your_api_key

# 本地联调用，不会发起真实模型请求
LLM_PROVIDER=mock

# 日志开关：是否启用日志输出
LOG_ENABLED=true

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=DEBUG

# 日志文件路径：不填时默认写入 logs/agent.log
LOG_FILE_PATH=

# 上传文件和 OCR/ASR/视频工具默认使用的本地目录
# 不填时默认回退到 /app/download
APP_DOWNLOAD_DIR=/app/download

# 本地工具路径：不填时优先从 PATH 自动发现
# OCR_TOOL_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# ASR_TOOL_PATH=D:\workspace\YeQianWorkSpace\yeqian_practise\agent\simple-ai-agent\.venv\Scripts\whisper.exe
# VIDEO_PROBE_TOOL_PATH=C:\path\to\ffprobe.exe
# VIDEO_FRAME_TOOL_PATH=C:\path\to\ffmpeg.exe
# VIDEO_AUDIO_TOOL_PATH=C:\path\to\ffmpeg.exe
