# ================================
# LLM 基础配置
# ================================

# 模型提供商。默认值：mock
# 可选值：openai / dashscope / doubao / custom / mock
LLM_PROVIDER=mock

# 模型名称。默认值：gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# OpenAI 兼容接口基础地址。默认值：空，表示使用 provider 内置默认地址
LLM_BASE_URL=

# 通用 API Key。默认值：空
LLM_API_KEY=

# OpenAI 专用 API Key。默认值：空
OPENAI_API_KEY=

# DashScope API Key。默认值：空
DASHSCOPE_API_KEY=

# 豆包 / 方舟 API Key。默认值：空
ARK_API_KEY=

# ================================
# 上传、数据库与日志
# ================================

# 上传与工具中间产物目录。默认值：/app/download
APP_DOWNLOAD_DIR=/app/download

# 数据库地址。默认值：sqlite:///data/agent.db
APP_DATABASE_URL=sqlite:///data/agent.db

# 是否启用日志。默认值：false
LOG_ENABLED=false

# 日志级别。默认值：INFO
LOG_LEVEL=INFO

# 日志文件路径。默认值：logs/agent.log
LOG_FILE_PATH=logs/agent.log

# ================================
# 统一鉴权与 RBAC
# ================================

# 是否启用统一鉴权。默认值：false
APP_AUTH_ENABLED=false

# 是否启用最小 RBAC。默认值：false
APP_RBAC_ENABLED=false

# 初始化管理员主体列表，逗号分隔。默认值：空
# 示例：apikey:demo-key,bearer:token123
APP_AUTH_ADMIN_SUBJECTS=

# API Key 列表，逗号分隔。默认值：空
APP_API_KEYS=

# Bearer Token 列表，逗号分隔。默认值：空
APP_BEARER_TOKENS=

# ================================
# 限流与幂等
# ================================

# 是否启用限流。默认值：false
APP_RATE_LIMIT_ENABLED=false

# 限流窗口内最大请求数。默认值：60
APP_RATE_LIMIT_REQUESTS=60

# 限流窗口秒数。默认值：60
APP_RATE_LIMIT_WINDOW_SECONDS=60

# 是否启用幂等。默认值：false
APP_IDEMPOTENCY_ENABLED=false

# 幂等缓存 TTL 秒数。默认值：300
APP_IDEMPOTENCY_TTL_SECONDS=300

# ================================
# LLM 重试与熔断
# ================================

# 是否启用模型重试。默认值：true
APP_LLM_RETRY_ENABLED=true

# 模型重试次数。默认值：2
APP_LLM_RETRY_ATTEMPTS=2

# 模型重试退避毫秒数。默认值：100
APP_LLM_RETRY_BACKOFF_MS=100

# 是否启用模型熔断。默认值：true
APP_LLM_CIRCUIT_ENABLED=true

# 模型熔断失败阈值。默认值：3
APP_LLM_CIRCUIT_FAILURE_THRESHOLD=3

# 模型熔断恢复秒数。默认值：30
APP_LLM_CIRCUIT_RECOVERY_SECONDS=30

# ================================
# 工具重试与熔断
# ================================

# 是否启用工具重试。默认值：true
APP_TOOL_RETRY_ENABLED=true

# 工具重试次数。默认值：2
APP_TOOL_RETRY_ATTEMPTS=2

# 工具重试退避毫秒数。默认值：100
APP_TOOL_RETRY_BACKOFF_MS=100

# 是否启用工具熔断。默认值：true
APP_TOOL_CIRCUIT_ENABLED=true

# 工具熔断失败阈值。默认值：3
APP_TOOL_CIRCUIT_FAILURE_THRESHOLD=3

# 工具熔断恢复秒数。默认值：30
APP_TOOL_CIRCUIT_RECOVERY_SECONDS=30

# ================================
# Workflow 执行协议与角色
# ================================

# 工作流执行协议。默认值：delegated
# 可选值：delegated / standard
APP_WORKFLOW_EXECUTION_MODE=delegated

# 是否启用 deliberation 路由。默认值：true
APP_WORKFLOW_DELIBERATION_ENABLED=true

# 触发 deliberation 路由的关键词，逗号分隔。默认值：比较,辩论,评审,优缺点,方案
APP_WORKFLOW_DELIBERATION_KEYWORDS=比较,辩论,评审,优缺点,方案

# 支持方角色名称。默认值：支持方代理
APP_WORKFLOW_SUPPORT_ROLE_NAME=支持方代理

# 支持方角色职责。默认值见代码
APP_WORKFLOW_SUPPORT_ROLE_INSTRUCTION=优先指出当前规划与最终回答应保留的强项和有效路径。

# 质疑方角色名称。默认值：质疑方代理
APP_WORKFLOW_CHALLENGE_ROLE_NAME=质疑方代理

# 质疑方角色职责。默认值见代码
APP_WORKFLOW_CHALLENGE_ROLE_INSTRUCTION=优先指出当前规划可能遗漏的风险、限制、反例或需要澄清的地方。

# 规划角色名称。默认值：规划代理
APP_WORKFLOW_PLANNER_ROLE_NAME=规划代理

# 规划角色职责。默认值见代码
APP_WORKFLOW_PLANNER_ROLE_INSTRUCTION=优先梳理用户目标、上下文约束、工具结果与执行路径，生成可执行计划。

# 执行角色名称。默认值：执行代理
APP_WORKFLOW_EXECUTOR_ROLE_NAME=执行代理

# 执行角色职责。默认值见代码
APP_WORKFLOW_EXECUTOR_ROLE_INSTRUCTION=优先依据规划、工具结果和仲裁结论生成最终可执行回答。

# 仲裁角色名称。默认值：仲裁代理
APP_WORKFLOW_ARBITRATION_ROLE_NAME=仲裁代理

# 仲裁角色职责。默认值见代码
APP_WORKFLOW_ARBITRATION_ROLE_INSTRUCTION=优先整理支持与质疑双方的观点，并给出最终可执行的取舍与输出要点。

# 批评角色名称。默认值：批评代理
APP_WORKFLOW_CRITIC_ROLE_NAME=批评代理

# 批评角色职责。默认值见代码
APP_WORKFLOW_CRITIC_ROLE_INSTRUCTION=优先指出答案的遗漏、风险和说明不足，并给出最关键的修改建议。

# 复核角色名称。默认值：复核代理
APP_WORKFLOW_REVIEWER_ROLE_NAME=复核代理

# 复核角色职责。默认值见代码
APP_WORKFLOW_REVIEWER_ROLE_INSTRUCTION=优先根据答案、工具结果和批评摘要给出复核结论与发布建议。

# ================================
# 安全边界与上传限制
# ================================

# 允许注册的工具名称列表，逗号分隔。默认值：空，表示不限制
APP_ALLOWED_TOOLS=

# 上传文件最大字节数。默认值：20971520
APP_UPLOAD_MAX_BYTES=20971520

# 允许上传的资产类型，逗号分隔。默认值：image,audio,video,file
APP_UPLOAD_ALLOWED_KINDS=image,audio,video,file

# ================================
# 恢复策略
# ================================

# 模型失败后是否降级到 mock。默认值：false
APP_RECOVERY_LLM_DEGRADE_TO_MOCK=false

# 工具失败后是否返回 soft-fail 结果而不直接抛错。默认值：false
APP_RECOVERY_TOOL_SOFT_FAIL=false

# ================================
# 异步任务预留
# ================================

# 是否启用异步任务提交能力。默认值：true
APP_ASYNC_TASK_ENABLED=true

# 本地后台执行器工作线程数。默认值：2
APP_ASYNC_TASK_WORKERS=2

# ================================
# 本地工具路径
# ================================

# OCR 工具路径。默认值：空，表示优先从 PATH 自动发现
OCR_TOOL_PATH=

# ASR 工具路径。默认值：空，表示优先从 PATH 自动发现
ASR_TOOL_PATH=

# 视频探测工具路径。默认值：空，表示优先从 PATH 自动发现
VIDEO_PROBE_TOOL_PATH=

# 视频抽帧工具路径。默认值：空，表示优先从 PATH 自动发现
VIDEO_FRAME_TOOL_PATH=

# 视频抽音轨工具路径。默认值：空，表示优先从 PATH 自动发现
VIDEO_AUDIO_TOOL_PATH=
