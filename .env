
# 豆包 / 火山方舟示例
LLM_PROVIDER=doubao
LLM_MODEL=doubao-seed-2-0-pro-260215
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=4d21f161-5cfd-4241-b39d-15ecbdff5778

# 调试开关：打印完整对话历史
DEBUG_CONVERSATION_HISTORY=true

# 日志开关：是否启用日志输出
LOG_ENABLED=false

# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO

# 日志文件路径：不填时默认写入 logs/agent.log
LOG_FILE_PATH=logs/stdout.log